{
  "name": "NFortConfig",
  "scopeName": "source.nfortconfig",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#numbers" },
    { "include": "#propertyName" },
    { "include": "#punct" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash", "match": "//.*$" },
        { "name": "comment.block", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.nfortconfig",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.nfortconfig", "match": "\\\\[\\\\\"nrtbfv]" },
            { "name": "constant.character.escape.nfortconfig", "match": "\\\\." }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "constant.language.boolean.nfortconfig", "match": "\\b(true|false)\\b" },
        { "name": "constant.language.null.nfortconfig", "match": "\\b(nullptr|null|NULL)\\b" }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.nfortconfig", "match": "\\b[+-]?(\\d+\\.\\d+|\\d+)\\b" }
      ]
    },
    "propertyName": {
      "patterns": [
        {
          "name": "entity.name.property.nfortconfig",
          "match": "(?<=^|\\s)([A-Za-z_][A-Za-z0-9_\\-\\.]*)(?=\\s*:)"
        }
      ]
    },
    "punct": {
      "patterns": [
        { "name": "punctuation.separator.key-value.nfortconfig", "match": ":" },
        { "name": "punctuation.section.block.begin.nfortconfig", "match": "\\{" },
        { "name": "punctuation.section.block.end.nfortconfig", "match": "\\}" }
      ]
    }
  }
}
